{
  "custom": {},
  "params": {
    "tagPath": ""
  },
  "props": {
    "defaultSize": {
      "width": 300,
      "height": 200
    }
  },
  "root": {
    "type": "ia.container.coord",
    "version": 0,
    "props": {
      "mode": "fixed"
    },
    "meta": {
      "name": "root"
    },
    "children": [
      {
        "type": "ia.display.label",
        "version": 0,
        "props": {
          "text": "--",
          "style": {
            "fontSize": 20,
            "color": "#42e898"
          }
        },
        "meta": {
          "name": "val"
        },
        "position": {
          "x": 10,
          "y": 10,
          "width": 200,
          "height": 30
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "type": "tag",
              "config": {
                "mode": "indirect",
                "references": {
                  "path": "{view.params.tagPath}"
                },
                "tagPath": "{path}",
                "fallbackDelay": 2.5
              }
            }
          }
        }
      }
    ]
  }
}