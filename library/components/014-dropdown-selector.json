{
  "id": "014",
  "name": "DropdownSelector",
  "desc": "Dropdown with options — writes selection to tag",
  "component": "ia.input.dropdown",
  "category": "input",
  "params": {
    "path": "",
    "label": "",
    "options": []
  },
  "bindings": [
    "value ↔ {path}"
  ],
  "children": [
    {
      "type": "ia.display.label",
      "version": 0,
      "props": {
        "text": "",
        "style": {
          "fontSize": 11,
          "color": "#98a8c0"
        }
      },
      "meta": {
        "name": "lbl"
      },
      "position": {
        "x": 8,
        "y": 6,
        "width": 100,
        "height": 18
      },
      "propConfig": {
        "props.text": {
          "binding": {
            "type": "property",
            "config": {
              "path": "view.params.label"
            }
          }
        }
      }
    },
    {
      "type": "ia.input.dropdown",
      "version": 0,
      "props": {
        "value": 0,
        "options": [
          {
            "label": "OFF",
            "value": 0
          },
          {
            "label": "HAND",
            "value": 1
          },
          {
            "label": "AUTO",
            "value": 2
          }
        ]
      },
      "meta": {
        "name": "dd"
      },
      "position": {
        "x": 120,
        "y": 2,
        "width": 120,
        "height": 28
      },
      "propConfig": {
        "props.value": {
          "binding": {
            "type": "tag",
            "config": {
              "mode": "indirect",
              "references": {
                "path": "{view.params.path}"
              },
              "tagPath": "{path}",
              "fallbackDelay": 2.5
            },
            "bidirectional": true
          }
        }
      }
    }
  ],
  "status": "verified"
}