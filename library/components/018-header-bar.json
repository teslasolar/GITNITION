{
  "id": "018",
  "name": "HeaderBar",
  "desc": "Top header dock with title + status + clock",
  "component": "ia.container.flex",
  "category": "container",
  "params": {
    "title": "Plant Overview",
    "status": "RUNNING"
  },
  "bindings": [],
  "children": [
    {
      "type": "ia.container.flex",
      "version": 0,
      "props": {
        "direction": "row",
        "alignItems": "center",
        "style": {
          "backgroundColor": "#0a0e16",
          "borderBottom": "1px solid #1a2030",
          "padding": "0 12px",
          "height": "48px",
          "gap": "8px"
        }
      },
      "meta": {
        "name": "bar"
      },
      "position": {
        "grow": 1
      },
      "children": [
        {
          "type": "ia.display.label",
          "version": 0,
          "props": {
            "text": "",
            "style": {
              "fontSize": 16,
              "fontWeight": "bold",
              "color": "#f57c20"
            }
          },
          "meta": {
            "name": "title"
          },
          "position": {
            "shrink": 0
          },
          "propConfig": {
            "props.text": {
              "binding": {
                "type": "property",
                "config": {
                  "path": "view.params.title"
                }
              }
            }
          }
        },
        {
          "type": "ia.display.label",
          "version": 0,
          "props": {
            "text": "● RUNNING",
            "style": {
              "fontSize": 10,
              "color": "#42e898"
            }
          },
          "meta": {
            "name": "status"
          },
          "position": {
            "grow": 1
          }
        }
      ]
    }
  ],
  "status": "verified"
}