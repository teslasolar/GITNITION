{
  "id": "012",
  "name": "NumericEntry",
  "desc": "Numeric input with label — writes back to tag",
  "component": "ia.input.numeric-entry",
  "category": "input",
  "params": {
    "path": "",
    "label": "",
    "min": 0,
    "max": 100
  },
  "bindings": [
    "value ↔ {path}"
  ],
  "children": [
    {
      "type": "ia.display.label",
      "version": 0,
      "props": {
        "text": "",
        "style": {
          "fontSize": 11,
          "color": "#98a8c0"
        }
      },
      "meta": {
        "name": "lbl"
      },
      "position": {
        "x": 8,
        "y": 6,
        "width": 100,
        "height": 18
      },
      "propConfig": {
        "props.text": {
          "binding": {
            "type": "property",
            "config": {
              "path": "view.params.label"
            }
          }
        }
      }
    },
    {
      "type": "ia.input.numeric-entry",
      "version": 0,
      "props": {
        "value": 0
      },
      "meta": {
        "name": "entry"
      },
      "position": {
        "x": 120,
        "y": 2,
        "width": 100,
        "height": 28
      },
      "propConfig": {
        "props.value": {
          "binding": {
            "type": "tag",
            "config": {
              "mode": "indirect",
              "references": {
                "path": "{view.params.path}"
              },
              "tagPath": "{path}",
              "fallbackDelay": 2.5
            },
            "bidirectional": true
          }
        }
      }
    }
  ],
  "status": "verified"
}